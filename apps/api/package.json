    "@types/pg": "^8.20.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.12.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.21.0",
    "prom-client": "^15.1.3",
    "socket.io": "^4.7.5",
    "uuid": "^10.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
