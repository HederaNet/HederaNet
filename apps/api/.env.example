# ─── Hedera Network ────────────────────────────────────────────────────────────
HEDERA_NETWORK=testnet
HEDERA_OPERATOR_ID=0.0.YOUR_ACCOUNT_ID
HEDERA_OPERATOR_PRIVATE_KEY=your_ecdsa_private_key_hex
HEDERA_MIRROR_NODE_URL=https://testnet.mirrornode.hedera.com

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hederanet

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth ──────────────────────────────────────────────────────────────────────
# Must be at least 32 characters — use: openssl rand -base64 32
JWT_SECRET=replace-with-a-32-plus-character-random-secret

# ─── Token IDs (testnet) ───────────────────────────────────────────────────────
HNET_TOKEN_ID=0.0.7153593
HEC_TOKEN_ID=0.0.7153605
HCC_TOKEN_ID=0.0.7153651
REPUTATION_NFT_ID=0.0.7153666

# Testnet USDC — run once after starting: pnpm --filter @hederanet/api deploy:usdc
# On mainnet, replace with Circle's official USDC token ID (0.0.456858)
# USDC_TOKEN_ID=0.0.XXXXXXX

# ─── Contract IDs (testnet) ────────────────────────────────────────────────────
ENERGY_TRADING_CONTRACT_ID=0.0.7153712
SERVICE_PAYMENT_CONTRACT_ID=0.0.7153764
GOVERNANCE_CONTRACT_ID=0.0.7153782

# ─── Topic IDs (testnet) ───────────────────────────────────────────────────────
GOVERNANCE_TOPIC_ID=0.0.1006
SERVICE_QUALITY_TOPIC_ID=0.0.1005
ENERGY_TRADING_TOPIC_ID=0.0.1007

# ─── Web App (CORS) ────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Google OAuth (optional) ───────────────────────────────────────────────────
# Required for Google sign-in. Create at console.cloud.google.com.
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-your-secret

# ─── Optional integrations ─────────────────────────────────────────────────────
# SENTRY_DSN=https://your-sentry-dsn
# MAPBOX_PUBLIC_TOKEN=pk.eyJ1...
# FLUTTERWAVE_SECRET_KEY=FLWSECK-...
# AFRICAS_TALKING_USERNAME=sandbox
# AFRICAS_TALKING_API_KEY=...

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
