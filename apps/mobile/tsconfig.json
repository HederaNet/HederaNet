{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "jsx": "react-native",
    "noEmit": true
  },
  "include": ["src", "app.json"],
  "exclude": [
    "node_modules",
    "../../hedera-services",
    "../../src",
    "../../__tests__",
    "../../App.tsx",
    "../../android",
    "../../ios",
    "../api",
    "../web"
  ]
}
