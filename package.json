{
  "name": "hederanet",
  "version": "1.0.0",
  "private": true,
  "description": "HederaNet — DePIN platform for African communities on Hedera Hashgraph",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "pnpm --recursive --filter './packages/*' build && pnpm --parallel --filter './apps/*' --filter './services/*' dev",
    "build": "pnpm --recursive --filter './packages/*' build && pnpm --recursive --filter './apps/*' --filter './services/*' build",
    "test": "pnpm --recursive test",
    "lint": "pnpm --recursive lint",
    "typecheck": "pnpm --recursive typecheck",
    "clean": "pnpm --recursive exec rm -rf dist node_modules .turbo",
    "db:migrate": "pnpm --filter './apps/api' db:migrate",
    "db:generate": "pnpm --filter './apps/api' db:generate"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0"
  }
}
